  "keyFeatures": [
    "Role-based access control (Coordinator, Teacher, Psycho-orientator)",
    "Student referral management system",
    "Psycho-orientation reports and tracking",
    "Academic degree and group management",
    "Student state tracking (Active, PIAR, DUA)",
    "Email notifications for referrals",
    "Password reset functionality",
    "Profile management with photo uploads"
  ],
  "publicApiSurface": [
    "POST /authenticate - User login",
    "GET /dashboard - Main dashboard",
    "POST /store/user - Create new user (Coordinator)",
    "POST /store/referral - Create student referral",
    "PUT /accept/student - Accept student to PIAR",
    "GET /index/students/remitted/psico - List referred students",
    "POST /store/report/student/{id} - Create psycho-orientation report",
    "GET /student/history/{id} - View student history",
    "PUT /profile/photo - Update profile photo",
    "POST /store/group - Create academic group",
    "POST /store/degree - Create academic degree",
    "POST /store/area - Create subject area"
  ]
